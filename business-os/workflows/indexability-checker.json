        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"text\": \"*Indexability Checker Alert*\\n\\n*Issues Found:* {{ $json.issueCount }}\\n\\n{{ $json.issues.map(i => '\u2022 [' + i.type + '] ' + i.issue + (i.url ? '\\n  ' + i.url : '')).join('\\n') }}\\n\\nThese issues may prevent Google from indexing your pages.\"}",
        "options": {}
