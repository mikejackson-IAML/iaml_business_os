      "id": "fetch-robots",
      "name": "Fetch robots.txt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        -50
      ]
    },
    {
      "parameters": {
        "jsCode": "// Check key pages for indexability issues\nconst pages = [\n  'https://www.iaml.com/',\n  'https://www.iaml.com/programs/employment-law-update',\n  'https://www.iaml.com/about'\n];\nreturn pages.map(url => ({ json: { url } }));"
      },
      "id": "get-pages",
      "name": "Get Pages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        100
      ]
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "options": {
          "timeout": 15000,
          "response": {
            "response": {
              "responseFormat": "text",
              "fullResponse": true
            }
          }
        }
      },
      "id": "fetch-page",
      "name": "Fetch Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Analyze indexability\nconst robots = $('Fetch robots.txt').first().json;\nconst pages = $('Fetch Page').all();\nconst issues = [];\n\n// Check robots.txt\nconst robotsTxt = robots.data || '';\nif (!robotsTxt) {\n  issues.push({ type: 'robots.txt', issue: 'robots.txt not found or empty' });\n}\nif (robotsTxt.includes('Disallow: /')) {\n  // Check if it's blocking everything\n  const lines = robotsTxt.split('\\n');\n  for (const line of lines) {\n    if (line.trim() === 'Disallow: /' && !line.includes('/programs')) {\n      issues.push({ type: 'robots.txt', issue: 'robots.txt may be blocking entire site' });\n    }\n  }\n}\n\n// Check each page\nfor (const page of pages) {\n  const html = page.json.data || page.json.body || '';\n  const url = page.json.url || 'unknown';\n  const headers = page.json.headers || {};\n  \n  // Check for noindex\n  if (html.includes('noindex') || html.match(/<meta[^>]*robots[^>]*noindex/i)) {\n    issues.push({ type: 'noindex', url, issue: 'Page has noindex tag' });\n  }\n  \n  // Check for nofollow\n  if (html.match(/<meta[^>]*robots[^>]*nofollow/i)) {\n    issues.push({ type: 'nofollow', url, issue: 'Page has nofollow tag' });\n  }\n  \n  // Check canonical\n  const canonicalMatch = html.match(/<link[^>]*rel=[\"']canonical[\"'][^>]*href=[\"']([^\"']+)/i);\n  if (!canonicalMatch) {\n    issues.push({ type: 'canonical', url, issue: 'Missing canonical tag' });\n  } else {\n    const canonical = canonicalMatch[1];\n    // Check if canonical points to different URL\n    if (canonical && !url.includes(canonical.replace('https://www.', '').replace('https://', ''))) {\n      issues.push({ type: 'canonical', url, issue: 'Canonical points to different URL: ' + canonical });\n    }\n  }\n  \n  // Check X-Robots-Tag header\n  const xRobots = headers['x-robots-tag'] || '';\n  if (xRobots.includes('noindex')) {\n    issues.push({ type: 'header', url, issue: 'X-Robots-Tag header contains noindex' });\n  }\n}\n\nreturn [{\n  json: {\n    checkedAt: new Date().toISOString(),\n    robotsTxtFound: !!robotsTxt,\n    pagesChecked: pages.length,\n    issues: issues,\n    issueCount: issues.length,\n    hasIssues: issues.length > 0\n  }\n}];"
      },
      "id": "analyze",
      "name": "Analyze Indexability",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ]
    },
