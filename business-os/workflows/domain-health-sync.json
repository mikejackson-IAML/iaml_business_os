        "columnValues": "={{ !$json.is_connected ? 'inbox_disconnected' : ($json.inbox_health_score < 70 ? 'inbox_health_warning' : 'inbox_health_critical') }}, Inbox {{ $json.inbox_email }} {{ !$json.is_connected ? 'disconnected' : 'health at ' + $json.inbox_health_score }}, smartlead, {\"inbox\": \"{{ $json.inbox_email }}\", \"health_score\": {{ $json.inbox_health_score }}, \"bounce_rate\": {{ $json.bounce_rate }}, \"is_connected\": {{ $json.is_connected }}}, NOW()"
      },
