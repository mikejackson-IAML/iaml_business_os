      "position": [2016, -100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/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",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \":mailbox_with_no_mail: *Inbox Alert*\\n\\n*Inbox:* {{ $json.inbox_email }}\\n*Status:* {{ !$json.is_connected ? 'DISCONNECTED' : 'Health Warning' }}\\n*Health Score:* {{ $json.inbox_health_score }}/100\\n*Bounce Rate:* {{ $json.bounce_rate }}%\\n*Reply Rate:* {{ $json.reply_rate }}%\\n{{ $json.last_error ? '*Error:* ' + $json.last_error : '' }}\\n\\nReview in Lead Intelligence Dashboard.\"\n}",
        "options": {}
      },
      "id": "slack-inbox-alert",
      "name": "Slack Inbox Alert",
      "type": "n8n-nodes-base.httpRequest",
