{
  "name": "Domain Health Sync - Daily",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Daily 6am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "url": "=https://server.smartlead.ai/api/v1/email-accounts?api_key={{ $env.SMARTLEAD_API_KEY }}",
        "options": {}
      },
      "id": "get-email-accounts",
      "name": "Get Email Accounts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [224, 0]
    },
    {
      "parameters": {
        "url": "=https://server.smartlead.ai/api/v1/analytics/mailbox/domain-wise-health?api_key={{ $env.SMARTLEAD_API_KEY }}",
        "options": {}
      },
      "id": "get-domain-health",
      "name": "Get Domain Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [224, 200]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition",
        "options": {}
      },
      "id": "merge-data",
      "name": "Merge Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [448, 100]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "domain_name",
              "name": "domain_name",
              "value": "={{ $json.from_email?.split('@')[1] ?? $json.domain ?? 'unknown' }}",
              "type": "string"
            },
            {
              "id": "inbox_email",
              "name": "inbox_email",
              "value": "={{ $json.from_email ?? '' }}",
              "type": "string"
            },
            {
              "id": "display_name",
              "name": "display_name",
              "value": "={{ $json.from_name ?? '' }}",
              "type": "string"
            },
            {
              "id": "status",
              "name": "status",
              "value": "={{ $json.warmup_enabled ? 'warming' : ($json.is_active ? 'active' : 'paused') }}",
              "type": "string"
            },
            {
              "id": "daily_limit",
              "name": "daily_limit",
              "value": "={{ $json.max_email_per_day ?? 50 }}",
              "type": "number"
            },
            {
              "id": "warmup_day",
              "name": "warmup_day",
              "value": "={{ $json.warmup_details?.warmup_day ?? null }}",
              "type": "number"
            },
            {
              "id": "warmup_enabled",
              "name": "warmup_enabled",
              "value": "={{ $json.warmup_enabled ?? false }}",
              "type": "boolean"
            },
            {
              "id": "warmup_target_limit",
              "name": "warmup_target_limit",
              "value": "={{ $json.warmup_details?.target_emails_per_day ?? null }}",
              "type": "number"
            },
            {
              "id": "bounce_rate",
              "name": "bounce_rate",
              "value": "={{ $json.bounce_rate ?? 0 }}",
              "type": "number"
            },
            {
              "id": "spam_rate",
              "name": "spam_rate",
              "value": "={{ $json.spam_rate ?? 0 }}",
              "type": "number"
            },
            {
              "id": "open_rate",
              "name": "open_rate",
              "value": "={{ $json.open_rate ?? 0 }}",
              "type": "number"
            },
            {
              "id": "reply_rate",
              "name": "reply_rate",
              "value": "={{ $json.reply_rate ?? 0 }}",
              "type": "number"
            },
            {
              "id": "sent_today",
              "name": "sent_today",
              "value": "={{ $json.sent_count_today ?? 0 }}",
              "type": "number"
            },
            {
              "id": "sent_this_week",
              "name": "sent_this_week",
              "value": "={{ $json.sent_count_week ?? 0 }}",
              "type": "number"
            },
            {
              "id": "is_connected",
              "name": "is_connected",
              "value": "={{ $json.is_connected ?? true }}",
              "type": "boolean"
            },
            {
              "id": "last_error",
              "name": "last_error",
              "value": "={{ $json.last_error ?? null }}",
              "type": "string"
            },
            {
              "id": "smartlead_account_id",
              "name": "smartlead_account_id",
              "value": "={{ $json.id }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "transform-domain-data",
      "name": "Transform Domain Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [672, 100]
    },
    {
      "parameters": {
        "url": "=https://api.mxtoolbox.com/api/v1/Lookup/blacklist/{{ $json.domain_name }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $env.MXTOOLBOX_API_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "check-blacklist",
      "name": "Check Blacklist",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [896, 100],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "blacklist_count",
              "name": "blacklist_count",
              "value": "={{ $json.Failed?.length ?? 0 }}",
              "type": "number"
            },
            {
              "id": "blacklist_score",
              "name": "blacklist_score",
              "value": "={{ ($json.Failed?.length ?? 0) === 0 ? 100 : ($json.Failed?.length < 3 ? 50 : 0) }}",
              "type": "number"
            },
            {
              "id": "health_score",
              "name": "health_score",
              "value": "={{ Math.round(Math.max(0, Math.min(100, (100 - ($('Transform Domain Data').item.json.bounce_rate * 10)) * 0.30 + (100 - ($('Transform Domain Data').item.json.spam_rate * 20)) * 0.30 + (($json.Failed?.length ?? 0) === 0 ? 100 : 0) * 0.20 + ($('Transform Domain Data').item.json.open_rate ?? 30) * 0.20))) }}",
              "type": "number"
            },
            {
              "id": "inbox_health_score",
              "name": "inbox_health_score",
              "value": "={{ Math.round(Math.max(0, Math.min(100, (100 - ($('Transform Domain Data').item.json.bounce_rate * 10)) * 0.30 + (100 - ($('Transform Domain Data').item.json.spam_rate * 20)) * 0.30 + (($('Transform Domain Data').item.json.reply_rate ?? 0) * 2) * 0.20 + ($('Transform Domain Data').item.json.is_connected ? 100 : 0) * 0.20))) }}",
              "type": "number"
            }
          ]
        },
        "includeOtherFields": true,
        "include": "selected",
        "options": {}
      },
      "id": "calculate-health-score",
      "name": "Calculate Health Score",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1120, 100]
    },
    {
      "parameters": {
        "operation": "upsert",
        "schema": "public",
        "table": "domains",
        "conflictColumns": ["domain_name"],
        "columns": "domain_name, status, daily_limit, warmup_day, health_score, bounce_rate, spam_rate, open_rate, sent_today, platform_domain_id, updated_at",
        "columnValues": "={{ $json.domain_name }}, {{ $json.status === 'paused' ? 'resting' : $json.status }}, {{ $json.daily_limit }}, {{ $json.warmup_day }}, {{ $json.health_score }}, {{ $json.bounce_rate }}, {{ $json.spam_rate }}, {{ $json.open_rate }}, {{ $json.sent_today }}, {{ $json.smartlead_account_id }}, NOW()"
      },
      "id": "upsert-domain",
      "name": "Upsert Domain",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1344, -100],
      "credentials": {
        "supabaseApi": {
          "id": "3CPchaCatw5WmkUQ",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": "public",
        "table": "domain_health_log",
        "columns": "domain_id, log_date, health_score, bounce_rate, spam_rate, open_rate, emails_sent, status",
        "columnValues": "={{ $json.domain_id }}, CURRENT_DATE, {{ $json.health_score }}, {{ $json.bounce_rate }}, {{ $json.spam_rate }}, {{ $json.open_rate }}, {{ $json.sent_today }}, {{ $json.status }}"
      },
      "id": "log-health",
      "name": "Log Domain History",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1568, -100],
      "credentials": {
        "supabaseApi": {
          "id": "3CPchaCatw5WmkUQ",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO email_inboxes (inbox_email, smartlead_account_id, display_name, status, sent_today, sent_this_week, daily_limit, bounce_rate, open_rate, reply_rate, spam_rate, warmup_enabled, warmup_day, warmup_target_limit, is_connected, last_error, health_score, domain_id)\nSELECT \n  '{{ $json.inbox_email }}',\n  '{{ $json.smartlead_account_id }}',\n  '{{ $json.display_name }}',\n  '{{ $json.status }}',\n  {{ $json.sent_today }},\n  {{ $json.sent_this_week }},\n  {{ $json.daily_limit }},\n  {{ $json.bounce_rate }},\n  {{ $json.open_rate }},\n  {{ $json.reply_rate }},\n  {{ $json.spam_rate }},\n  {{ $json.warmup_enabled }},\n  {{ $json.warmup_day ?? 'NULL' }},\n  {{ $json.warmup_target_limit ?? 'NULL' }},\n  {{ $json.is_connected }},\n  {{ $json.last_error ? \"'\" + $json.last_error.replace(/'/g, \"''\") + \"'\" : 'NULL' }},\n  {{ $json.inbox_health_score }},\n  d.id\nFROM domains d\nWHERE d.domain_name = '{{ $json.domain_name }}'\nON CONFLICT (inbox_email) DO UPDATE SET\n  smartlead_account_id = EXCLUDED.smartlead_account_id,\n  display_name = EXCLUDED.display_name,\n  status = EXCLUDED.status,\n  sent_today = EXCLUDED.sent_today,\n  sent_this_week = EXCLUDED.sent_this_week,\n  daily_limit = EXCLUDED.daily_limit,\n  bounce_rate = EXCLUDED.bounce_rate,\n  open_rate = EXCLUDED.open_rate,\n  reply_rate = EXCLUDED.reply_rate,\n  spam_rate = EXCLUDED.spam_rate,\n  warmup_enabled = EXCLUDED.warmup_enabled,\n  warmup_day = EXCLUDED.warmup_day,\n  warmup_target_limit = EXCLUDED.warmup_target_limit,\n  is_connected = EXCLUDED.is_connected,\n  last_error = EXCLUDED.last_error,\n  health_score = EXCLUDED.health_score,\n  domain_id = EXCLUDED.domain_id,\n  updated_at = NOW()"
      },
      "id": "upsert-inbox",
      "name": "Upsert Inbox",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1344, 100],
      "credentials": {
        "postgres": {
          "id": "EgmvZHbvINHsh6PR",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO inbox_health_log (inbox_id, log_date, health_score, bounce_rate, spam_rate, open_rate, reply_rate, emails_sent, status)\nSELECT \n  i.id,\n  CURRENT_DATE,\n  {{ $json.inbox_health_score }},\n  {{ $json.bounce_rate }},\n  {{ $json.spam_rate }},\n  {{ $json.open_rate }},\n  {{ $json.reply_rate }},\n  {{ $json.sent_today }},\n  '{{ $json.status }}'\nFROM email_inboxes i\nWHERE i.inbox_email = '{{ $json.inbox_email }}'\nON CONFLICT (inbox_id, log_date) DO UPDATE SET\n  health_score = EXCLUDED.health_score,\n  bounce_rate = EXCLUDED.bounce_rate,\n  spam_rate = EXCLUDED.spam_rate,\n  open_rate = EXCLUDED.open_rate,\n  reply_rate = EXCLUDED.reply_rate,\n  emails_sent = EXCLUDED.emails_sent,\n  status = EXCLUDED.status"
      },
      "id": "log-inbox-health",
      "name": "Log Inbox History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1568, 100],
      "credentials": {
        "postgres": {
          "id": "EgmvZHbvINHsh6PR",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-domain-health",
              "leftValue": "={{ $json.health_score }}",
              "rightValue": 70,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "check-domain-alerts",
      "name": "Domain Health < 70?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1792, -100]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-inbox-health",
              "leftValue": "={{ $json.inbox_health_score }}",
              "rightValue": 70,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            },
            {
              "id": "check-disconnected",
              "leftValue": "={{ $json.is_connected }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "check-high-bounce",
              "leftValue": "={{ $json.bounce_rate }}",
              "rightValue": 5,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "check-inbox-alerts",
      "name": "Inbox Issues?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1792, 100]
