            {"id": "company_name", "name": "company_name", "value": "={{ $json.fields['Company Name (from Contact)']?.[0] ?? $json.fields['Company Name'] ?? '' }}", "type": "string"},
            {"id": "registration_date", "name": "registration_date", "value": "={{ $json.fields['Created Date'] ?? $json.createdTime }}", "type": "string"},
            {"id": "registration_source", "name": "registration_source", "value": "={{ $json.fields['Registration Source'] ?? 'Website' }}", "type": "string"},
            {"id": "registration_status", "name": "registration_status", "value": "={{ $json.fields['Registration Status'] ?? 'Confirmed' }}", "type": "string"},
            {"id": "registration_code", "name": "registration_code", "value": "={{ $json.fields['Registration Code'] ?? $json.fields['Registration ID'] ?? '' }}", "type": "string"},
            {"id": "list_price", "name": "list_price", "value": "={{ $json.fields['List Price'] ?? 0 }}", "type": "number"},
