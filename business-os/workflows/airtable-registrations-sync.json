        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"unique_identifier\": \"{{ $json.airtable_id }}\",\n  \"first_name\": \"{{ $json.first_name || '' }}\",\n  \"last_name\": \"{{ $json.last_name || '' }}\",\n  \"title\": \"{{ $json.job_title || '' }}\",\n  \"company_name\": \"{{ $json.company_name || '' }}\",\n  \"phone\": \"{{ $json.phone || '' }}\",\n  \"email\": \"{{ $json.email || '' }}\",\n  \"selected_program\": \"{{ $json.program_name || '' }}\",\n  \"program_format\": \"{{ $json.program_format || '' }}\",\n  \"selected_location\": \"{{ $json.session_location || '' }}\",\n  \"program_start_date\": \"{{ $json.session_start_date || '' }}\",\n  \"program_end_date\": \"{{ $json.session_end_date || '' }}\",\n  \"attendance_type__3_block_programs\": \"{{ $json.attendance_type || 'Full' }}\",\n  \"coupon_code_used\": \"{{ $json.coupon_code || '' }}\",\n  \"discount_amount\": {{ $json.discount_amount || 0 }},\n  \"registration_code\": \"{{ $json.registration_code || '' }}\",\n  \"amount_due\": {{ $json.final_price || 0 }},\n  \"payment_status\": \"{{ $json.payment_status || '' }}\",\n  \"registration_status\": \"{{ $json.registration_status || '' }}\",\n  \"registration_date\": \"{{ $json.registration_date || '' }}\",\n  \"utm_source\": \"{{ $json.utm_source || '' }}\",\n  \"utm_medium\": \"{{ $json.utm_medium || '' }}\",\n  \"utm_campaign\": \"{{ $json.utm_campaign || '' }}\",\n  \"tags\": [\"n8n_sync\", \"airtable_registration\"]\n}",
        "options": {
