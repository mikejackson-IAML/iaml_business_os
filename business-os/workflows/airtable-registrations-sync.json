            {"id": "final_price", "name": "final_price", "value": "={{ $json.fields['Final Price'] ?? $json.fields['Total Amount'] ?? 0 }}", "type": "number"},
            {"id": "payment_status", "name": "payment_status", "value": "={{ $json.fields['Payment Status'] ?? 'Pending' }}", "type": "string"},
            {"id": "payment_method", "name": "payment_method", "value": "={{ $json.fields['Payment Method'] ?? '' }}", "type": "string"},
