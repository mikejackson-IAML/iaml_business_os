    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE registrations r\nSET program_instance_id = pi.id\nFROM program_instances pi\nWHERE r.program_instance_airtable_id = pi.airtable_id\n  AND r.program_instance_id IS NULL"
      },
