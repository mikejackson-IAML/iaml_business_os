    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO registrations (\n  airtable_id,\n  program_instance_airtable_id,\n  contact_airtable_id,\n  first_name,\n  last_name,\n  email,\n  phone,\n  job_title,\n  company_airtable_id,\n  company_name,\n  registration_date,\n  registration_source,\n  registration_status,\n  registration_code,\n  list_price,\n  discount_amount,\n  final_price,\n  payment_status,\n  payment_method,\n  stripe_payment_intent,\n  stripe_invoice_id,\n  attendance_type,\n  selected_blocks,\n  utm_source,\n  utm_medium,\n  utm_campaign\n) VALUES (\n  '{{ $json.airtable_id }}',\n  {{ $json.program_instance_airtable_id ? \"'\" + $json.program_instance_airtable_id + \"'\" : 'NULL' }},\n  {{ $json.contact_airtable_id ? \"'\" + $json.contact_airtable_id + \"'\" : 'NULL' }},\n  '{{ ($json.first_name || '').replace(/'/g, \"''\") }}',\n  '{{ ($json.last_name || '').replace(/'/g, \"''\") }}',\n  '{{ $json.email || '' }}',\n  {{ $json.phone ? \"'\" + $json.phone + \"'\" : 'NULL' }},\n  {{ $json.job_title ? \"'\" + $json.job_title.replace(/'/g, \"''\") + \"'\" : 'NULL' }},\n  {{ $json.company_airtable_id ? \"'\" + $json.company_airtable_id + \"'\" : 'NULL' }},\n  {{ $json.company_name ? \"'\" + $json.company_name.replace(/'/g, \"''\") + \"'\" : 'NULL' }},\n  '{{ $json.registration_date }}',\n  '{{ $json.registration_source }}',\n  '{{ $json.registration_status }}',\n  {{ $json.registration_code ? \"'\" + $json.registration_code + \"'\" : 'NULL' }},\n  {{ $json.list_price }},\n  {{ $json.discount_amount }},\n  {{ $json.final_price }},\n  '{{ $json.payment_status }}',\n  {{ $json.payment_method ? \"'\" + $json.payment_method + \"'\" : 'NULL' }},\n  {{ $json.stripe_payment_intent ? \"'\" + $json.stripe_payment_intent + \"'\" : 'NULL' }},\n  {{ $json.stripe_invoice_id ? \"'\" + $json.stripe_invoice_id + \"'\" : 'NULL' }},\n  '{{ $json.attendance_type }}',\n  {{ $json.selected_blocks ? \"ARRAY[\" + $json.selected_blocks.map(b => \"'\" + b + \"'\").join(',') + \"]\" : 'NULL' }},\n  {{ $json.utm_source ? \"'\" + $json.utm_source + \"'\" : 'NULL' }},\n  {{ $json.utm_medium ? \"'\" + $json.utm_medium + \"'\" : 'NULL' }},\n  {{ $json.utm_campaign ? \"'\" + $json.utm_campaign + \"'\" : 'NULL' }}\n)\nON CONFLICT (airtable_id) DO UPDATE SET\n  program_instance_airtable_id = EXCLUDED.program_instance_airtable_id,\n  first_name = EXCLUDED.first_name,\n  last_name = EXCLUDED.last_name,\n  email = EXCLUDED.email,\n  phone = EXCLUDED.phone,\n  job_title = EXCLUDED.job_title,\n  company_airtable_id = EXCLUDED.company_airtable_id,\n  company_name = EXCLUDED.company_name,\n  registration_status = EXCLUDED.registration_status,\n  list_price = EXCLUDED.list_price,\n  discount_amount = EXCLUDED.discount_amount,\n  final_price = EXCLUDED.final_price,\n  payment_status = EXCLUDED.payment_status,\n  payment_method = EXCLUDED.payment_method,\n  stripe_payment_intent = EXCLUDED.stripe_payment_intent,\n  stripe_invoice_id = EXCLUDED.stripe_invoice_id,\n  attendance_type = EXCLUDED.attendance_type,\n  selected_blocks = EXCLUDED.selected_blocks,\n  updated_at = NOW()"
      },
