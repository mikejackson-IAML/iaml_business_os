        [{"node": "Log Sync Complete", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  },
  "pinData": {},
  "triggerCount": 1,
  "tags": [
    {"name": "lead-intelligence"},
    {"name": "inbox-tracking"},
    {"name": "smartlead"}
