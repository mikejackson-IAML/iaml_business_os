    {
      "id": "check-dedupe",
      "name": "Check for Duplicate",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2200, 300],
      "credentials": {
        "postgres": {
          "id": "EgmvZHbvINHsh6PR",
          "name": "Supabase Postgres"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Check for existing open task with same dedupe_key\n-- Also respect dismissed task cooldown\nWITH dedupe_key AS (\n  SELECT '{{ $json.alert_type }}:{{ $json.affected_resource }}' AS key\n)\nSELECT \n  t.id,\n  t.title,\n  t.priority,\n  t.status,\n  t.completed_at,\n  t.dismissed_at,\n  CASE \n    WHEN t.status IN ('open', 'in_progress') THEN 'duplicate_open'\n    WHEN t.dismissed_at IS NOT NULL \n      AND t.dismissed_at > NOW() - INTERVAL '{{ $json.config.dismissed_cooldown_days }} days' \n    THEN 'dismissed_recently'\n    WHEN t.completed_at IS NOT NULL \n      AND t.completed_at > NOW() - INTERVAL '{{ $json.config.cooldown_after_completion_hours }} hours' \n    THEN 'completed_recently'\n    ELSE 'none'\n  END AS duplicate_status\nFROM action_center.tasks t, dedupe_key\nWHERE t.dedupe_key = dedupe_key.key\n  AND (\n    t.status IN ('open', 'in_progress')\n    OR (t.dismissed_at > NOW() - INTERVAL '{{ $json.config.dismissed_cooldown_days }} days')\n    OR (t.completed_at > NOW() - INTERVAL '{{ $json.config.cooldown_after_completion_hours }} hours')\n  )\nORDER BY t.created_at DESC\nLIMIT 1;",
        "options": {}
      }
    },
    {
      "id": "dedupe-handler",
      "name": "Handle Duplicate Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 300],
      "parameters": {
        "jsCode": "// Handle dedupe check result\nconst prevData = $('Merge All Paths').first().json;\nconst dupeResult = $input.first().json;\n\n// Build dedupe_key for new task\nconst dedupeKey = `${prevData.alert_type}:${prevData.affected_resource}`;\n\n// Check if we found a duplicate\nconst hasDuplicate = dupeResult && dupeResult.id;\nconst duplicateStatus = hasDuplicate ? dupeResult.duplicate_status : 'none';\n\nlet action = 'create';\nlet existingTaskId = null;\nlet shouldEscalate = false;\n\nif (hasDuplicate) {\n  existingTaskId = dupeResult.id;\n  \n  if (duplicateStatus === 'duplicate_open') {\n    // Check if we should escalate priority\n    const priorityOrder = { 'low': 0, 'normal': 1, 'high': 2, 'critical': 3 };\n    const existingPriority = priorityOrder[dupeResult.priority] || 0;\n    const newPriority = priorityOrder[prevData.task_priority] || 0;\n    \n    if (newPriority > existingPriority) {\n      action = 'escalate';\n      shouldEscalate = true;\n    } else {\n      action = 'skip_duplicate';\n    }\n  } else if (duplicateStatus === 'dismissed_recently') {\n    action = 'skip_dismissed';\n  } else if (duplicateStatus === 'completed_recently') {\n    action = 'skip_cooldown';\n  }\n}\n\nreturn [{\n  json: {\n    ...prevData,\n    dedupe_key: dedupeKey,\n    action: action,\n    existing_task_id: existingTaskId,\n    should_escalate: shouldEscalate,\n    existing_priority: hasDuplicate ? dupeResult.priority : null\n  }\n}];"
      }
    },
