    {
      "id": "validate-payload",
      "name": "Validate Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300],
      "parameters": {
        "jsCode": "// Validate required fields in alert webhook payload\nconst payload = $input.first().json;\n\nconst requiredFields = ['alert_type', 'severity', 'title', 'affected_resource'];\nconst missing = requiredFields.filter(field => !payload[field]);\n\nif (missing.length > 0) {\n  throw new Error(`Missing required fields: ${missing.join(', ')}`);\n}\n\n// Validate severity enum\nconst validSeverities = ['critical', 'warning', 'info'];\nif (!validSeverities.includes(payload.severity)) {\n  throw new Error(`Invalid severity: ${payload.severity}. Must be one of: ${validSeverities.join(', ')}`);\n}\n\n// Pass through validated payload\nreturn [{\n  json: {\n    alert_type: payload.alert_type,\n    severity: payload.severity,\n    title: payload.title,\n    description: payload.description || '',\n    affected_resource: payload.affected_resource,\n    source_system: payload.source_system || null,\n    source_alert_id: payload.source_alert_id || null,\n    metadata: payload.metadata || {}\n  }\n}];"
      }
    },
    {
      "id": "get-config",
      "name": "Get Alert Config",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [440, 300],
      "credentials": {
        "postgres": {
          "id": "EgmvZHbvINHsh6PR",
          "name": "Supabase Postgres"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  id,\n  alert_type,\n  display_name,\n  creates_tasks,\n  default_department,\n  task_title_template,\n  info_creates_task,\n  accumulation_threshold,\n  accumulation_window_hours,\n  cooldown_after_completion_hours,\n  dismissed_cooldown_days\nFROM action_center.alert_config \nWHERE alert_type = '{{ $json.alert_type }}'\nLIMIT 1;",
        "options": {}
      }
    },
    {
      "id": "merge-config",
      "name": "Merge Config with Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "parameters": {
        "jsCode": "// Merge config with payload, using defaults if config not found\nconst payload = $('Validate Payload').first().json;\nconst configResult = $input.first().json;\n\n// Default config if none found in database\nconst defaultConfig = {\n  creates_tasks: true,\n  default_department: null,\n  task_title_template: null,\n  info_creates_task: false,\n  accumulation_threshold: 3,\n  accumulation_window_hours: 24,\n  cooldown_after_completion_hours: 24,\n  dismissed_cooldown_days: 7\n};\n\n// Use database config if found, otherwise defaults\nconst config = configResult.id ? configResult : defaultConfig;\n\nreturn [{\n  json: {\n    ...payload,\n    config: config\n  }\n}];"
      }
    },
    {
