    {
      "id": "info-handler",
      "name": "Check Info Exceptions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 500],
      "parameters": {
        "jsCode": "// Check if info alert should create a task\n// Exception 1: info_creates_task config flag is true\n// Exception 2: accumulation threshold reached (3x in 24h)\n\nconst data = $input.first().json;\nconst config = data.config;\n\nconst shouldProceed = \n  config.info_creates_task === true || \n  data.should_create_task_from_accumulation === true;\n\nreturn [{\n  json: {\n    ...data,\n    task_priority: 'low',\n    proceed_to_task: shouldProceed,\n    skip_reason: shouldProceed ? null : 'Info alert - no exceptions triggered'\n  }\n}];"
      }
    },
