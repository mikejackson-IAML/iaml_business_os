      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM action_center.record_alert_occurrence(\n  '{{ $json.alert_type }}'::TEXT,\n  '{{ $json.affected_resource }}'::TEXT,\n  '{{ $json.severity }}'::TEXT,\n  '{{ $json.title }}'::TEXT,\n  {{ $json.source_alert_id ? \"'\" + $json.source_alert_id + \"'\" : 'NULL' }}::TEXT,\n  {{ $json.source_system ? \"'\" + $json.source_system + \"'\" : 'NULL' }}::TEXT\n);",
        "options": {}
