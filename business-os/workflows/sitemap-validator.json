        "method": "POST",
        "url": "https://hooks.slack.com/services/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",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"text\": \"*Sitemap Validator Alert*\\n\\n*Issues Found:* {{ $json.issueCount }}\\n\\n{{ $json.issues.map(i => '\u2022 ' + i).join('\\n') }}\\n\\n*Total URLs:* {{ $json.totalUrls }}\"}",
        "options": {}
      },
      "id": "slack",
      "name": "Slack Alert",
