  "name": "Sitemap Validator - iaml.com",
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      },
      "id": "schedule",
      "name": "Daily Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://www.iaml.com/sitemap.xml",
        "options": {
          "timeout": 30000
        }
      },
      "id": "fetch-sitemap",
      "name": "Fetch Sitemap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Validate sitemap XML\nconst response = $input.first().json;\nconst xml = response.data || '';\nconst issues = [];\n\n// Check if valid XML\nif (!xml.includes('<?xml') && !xml.includes('<urlset')) {\n  issues.push('Invalid XML format - missing XML declaration or urlset');\n}\n\n// Extract URLs\nconst urlRegex = /<loc>(.*?)<\\/loc>/g;\nconst urls = [];\nlet match;\nwhile ((match = urlRegex.exec(xml)) !== null) {\n  urls.push(match[1]);\n}\n\n// Check for common issues\nif (urls.length === 0) {\n  issues.push('No URLs found in sitemap');\n}\n\n// Check for duplicate URLs\nconst duplicates = urls.filter((url, i) => urls.indexOf(url) !== i);\nif (duplicates.length > 0) {\n  issues.push(`Found ${duplicates.length} duplicate URLs`);\n}\n\n// Check for non-HTTPS URLs\nconst httpUrls = urls.filter(u => u.startsWith('http://'));\nif (httpUrls.length > 0) {\n  issues.push(`Found ${httpUrls.length} non-HTTPS URLs`);\n}\n\n// Check for missing trailing consistency\nconst withSlash = urls.filter(u => u.endsWith('/'));\nconst withoutSlash = urls.filter(u => !u.endsWith('/') && !u.includes('.'));\n\nreturn [{\n  json: {\n    checkedAt: new Date().toISOString(),\n    totalUrls: urls.length,\n    issues: issues,\n    issueCount: issues.length,\n    hasIssues: issues.length > 0,\n    duplicateCount: duplicates.length,\n    sampleUrls: urls.slice(0, 5)\n  }\n}];"
      },
      "id": "validate",
      "name": "Validate Sitemap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-issues",
              "leftValue": "={{ $json.hasIssues }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-issues",
      "name": "Has Issues?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "status",
              "name": "status",
              "value": "ok",
              "type": "string"
            },
            {
              "id": "msg",
              "name": "message",
              "value": "={{ 'Sitemap valid: ' + $json.totalUrls + ' URLs' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "ok",
      "name": "Sitemap OK",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        880,
        -100
      ]
    },
    {
