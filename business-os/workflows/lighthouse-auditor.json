      ]
    },
    {
      "parameters": {
        "url": "https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=https://www.iaml.com&strategy=desktop&category=performance&category=accessibility&category=best-practices&category=seo",
        "options": {
          "timeout": 120000
        }
      },
      "id": "psi-desktop",
      "name": "PageSpeed Desktop",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse PageSpeed Insights results\nconst mobile = $('PageSpeed Mobile').first().json;\nconst desktop = $('PageSpeed Desktop').first().json;\n\nfunction getScores(data, device) {\n  const cats = data.lighthouseResult?.categories || {};\n  return {\n    device: device,\n    performance: Math.round((cats.performance?.score || 0) * 100),\n    accessibility: Math.round((cats.accessibility?.score || 0) * 100),\n    bestPractices: Math.round((cats['best-practices']?.score || 0) * 100),\n    seo: Math.round((cats.seo?.score || 0) * 100)\n  };\n}\n\nconst mobileScores = getScores(mobile, 'mobile');\nconst desktopScores = getScores(desktop, 'desktop');\n\n// Core Web Vitals from mobile\nconst audits = mobile.lighthouseResult?.audits || {};\nconst cwv = {\n  lcp: audits['largest-contentful-paint']?.displayValue || 'N/A',\n  fid: audits['max-potential-fid']?.displayValue || 'N/A',\n  cls: audits['cumulative-layout-shift']?.displayValue || 'N/A',\n  fcp: audits['first-contentful-paint']?.displayValue || 'N/A',\n  ttfb: audits['server-response-time']?.displayValue || 'N/A'\n};\n\n// Determine if scores are concerning (below 50)\nconst minScore = Math.min(\n  mobileScores.performance, \n  desktopScores.performance\n);\nconst needsAttention = minScore < 50;\n\nconst result = {\n  url: 'https://www.iaml.com',\n  checkedAt: new Date().toISOString(),\n  mobile: mobileScores,\n  desktop: desktopScores,\n  coreWebVitals: cwv,\n  needsAttention: needsAttention,\n  lowestScore: minScore\n};\n\nreturn [{ json: result }];"
      },
      "id": "parse-results",
      "name": "Parse Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
