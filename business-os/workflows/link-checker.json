        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"*Link Checker Alert: Broken Links Found*\\n\\n*Total Checked:* {{ $json.totalChecked }}\\n*Broken Links:* {{ $json.brokenCount }}\\n\\n{{ $json.brokenLinks.map(l => '\u2022 ' + l.url + ' (Status: ' + l.statusCode + ')').join('\\n') }}\\n\\n*Checked At:* {{ $json.checkedAt }}\"\n}",
        "options": {}
      },
