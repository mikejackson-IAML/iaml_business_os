  "name": "Link Checker - iaml.com",
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Daily Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://www.iaml.com/sitemap.xml",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "fetch-sitemap",
      "name": "Fetch Sitemap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse sitemap XML and extract URLs\nconst xml = $input.first().json.data;\nconst urlRegex = /<loc>(.*?)<\\/loc>/g;\nconst urls = [];\nlet match;\n\nwhile ((match = urlRegex.exec(xml)) !== null) {\n  urls.push({ url: match[1] });\n}\n\nconsole.log(`Found ${urls.length} URLs in sitemap`);\nreturn urls.map(u => ({ json: u }));"
      },
      "id": "parse-urls",
      "name": "Parse URLs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": true
            }
          }
        }
      },
      "id": "check-url",
      "name": "Check URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Collect results and identify broken links\nconst items = $input.all();\nconst results = {\n  totalChecked: items.length,\n  brokenLinks: [],\n  checkedAt: new Date().toISOString()\n};\n\nfor (const item of items) {\n  const statusCode = item.json.statusCode || 0;\n  const url = item.json.url || 'unknown';\n  \n  // Consider 2xx and 3xx as OK\n  if (statusCode < 200 || statusCode >= 400) {\n    results.brokenLinks.push({\n      url: url,\n      statusCode: statusCode,\n      error: item.json.error?.message || 'Unknown error'\n    });\n  }\n}\n\nresults.hasBrokenLinks = results.brokenLinks.length > 0;\nresults.brokenCount = results.brokenLinks.length;\n\nconsole.log(`Checked ${results.totalChecked} URLs, found ${results.brokenCount} broken`);\n\nreturn [{ json: results }];"
      },
      "id": "collect-results",
      "name": "Collect Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-broken",
              "leftValue": "={{ $json.hasBrokenLinks }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-broken",
      "name": "Has Broken Links?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        0
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "status",
              "name": "status",
              "value": "ok",
              "type": "string"
            },
            {
              "id": "message",
              "name": "message",
              "value": "={{ 'All ' + $json.totalChecked + ' links OK' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "all-ok",
      "name": "All Links OK",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1320,
        -100
      ]
    },
