    {
      "parameters": {
        "resource": "mail",
        "operation": "send",
        "fromEmail": "faculty@iaml.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=New Opening: {{ $json.program_name }} - {{ $json.block_name }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; }\n    .header { background: #1a365d; color: white; padding: 20px; text-align: center; }\n    .content { padding: 30px; }\n    .program-details { background: #f7fafc; border-left: 4px solid #3182ce; padding: 15px; margin: 20px 0; }\n    .cta-button { display: inline-block; background: #3182ce; color: white !important; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold; margin: 20px 0; }\n    .urgency { background: #fed7d7; border-left: 4px solid #c53030; padding: 12px 15px; margin: 20px 0; color: #742a2a; }\n    .footer { color: #718096; font-size: 12px; padding: 20px; border-top: 1px solid #e2e8f0; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1 style=\"margin: 0;\">Teaching Opportunity Just Opened!</h1>\n  </div>\n  <div class=\"content\">\n    <p>Hi {{ $json.first_name }},</p>\n    \n    <p><strong>Great news!</strong> A teaching spot has just become available.</p>\n    \n    <div class=\"program-details\">\n      <p style=\"margin: 0 0 10px 0;\"><strong>Program:</strong> {{ $json.program_name }}</p>\n      <p style=\"margin: 0 0 10px 0;\"><strong>Location:</strong> {{ $json.city }}, {{ $json.state }}</p>\n      <p style=\"margin: 0 0 10px 0;\"><strong>Block:</strong> {{ $json.block_name }}</p>\n      <p style=\"margin: 0;\"><strong>Start Date:</strong> {{ $json.start_date }}</p>\n    </div>\n    \n    <div class=\"urgency\">\n      <strong>Act Fast!</strong> This spot was just released and is available on a first-come, first-served basis.\n    </div>\n    \n    <p style=\"text-align: center;\">\n      <a href=\"https://faculty.iaml.com/schedule?token={{ $json.magic_token }}\" class=\"cta-button\">Claim This Spot</a>\n    </p>\n    \n    <p>If you're interested in this teaching opportunity, click the button above to claim it before someone else does.</p>\n    \n    <p>Best regards,<br>IAML Faculty Scheduling</p>\n  </div>\n  <div class=\"footer\">\n    <p>This email was sent because you are qualified to teach this program. If you no longer wish to receive teaching opportunity notifications, please contact us.</p>\n  </div>\n</body>\n</html>",
        "options": {}
