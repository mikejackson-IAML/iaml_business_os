        "operation": "executeQuery",
        "query": "SELECT\n  sp.id,\n  sp.name,\n  sp.city,\n  sp.state,\n  sp.status,\n  sp.start_date,\n  CASE sp.status\n    WHEN 'tier_0' THEN 0\n    WHEN 'tier_1' THEN 1\n    WHEN 'tier_2' THEN 2\n    ELSE -1\n  END as current_tier\nFROM faculty_scheduler.scheduled_programs sp\nWHERE sp.id = '{{ $json.program_id }}'::UUID",
        "options": {
          "queryReplacement": "={{ $json.program_id }}"
        }
      },
