{
  "name": "Sales Navigator Results Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sales-nav-results",
        "options": {}
      },
      "id": "snr-webhook-trigger",
      "name": "Webhook: Apify Callback",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-1800, 400],
      "webhookId": "sales-nav-results"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 10
            }
          ]
        }
      },
      "id": "snr-schedule-trigger",
      "name": "Schedule: Check Completed",
