    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.apify.com/v2/datasets/{{ $json.apify_dataset_id }}/items",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "format",
              "value": "json"
            },
            {
              "name": "clean",
              "value": "true"
            }
          ]
        },
        "options": {}
      },
      "id": "snr-fetch-results",
      "name": "Fetch Dataset Results",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [200, 304],
      "credentials": {
        "httpQueryAuth": {
          "id": "apify-token",
          "name": "Apify API Token"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const results = $input.first().json;\nconst searchInfo = $('Was Successful?').first().json;\n\nlet profiles = Array.isArray(results) ? results : (results.data || results.items || []);\n\nif (!profiles || profiles.length === 0) {\n  return {\n    json: {\n      search_id: searchInfo.search_id,\n      profiles_count: 0,\n      profiles: [],\n      message: 'No profiles found in search results'\n    }\n  };\n}\n\nconst transformedProfiles = profiles.map(p => ({\n  linkedin_id: p.id || p.memberId,\n  linkedin_url: p.linkedinUrl || p.profileUrl,\n  public_identifier: p.publicIdentifier || p.username,\n  first_name: p.firstName,\n  last_name: p.lastName,\n  full_name: p.fullName || `${p.firstName || ''} ${p.lastName || ''}`.trim(),\n  headline: p.headline,\n  location: p.location?.linkedinText || p.location?.text || p.location,\n  location_parsed: typeof p.location === 'object' ? p.location.parsed : null,\n  current_company: p.currentPosition?.[0]?.companyName || p.company,\n  current_title: p.currentPosition?.[0]?.position || p.headline?.split(' at ')?.[0] || p.title,\n  about: p.about,\n  photo_url: p.photo,\n  is_premium: p.premium || false,\n  is_open_to_work: p.openToWork || false,\n  is_hiring: p.hiring || false,\n  connections_count: p.connectionsCount,\n  follower_count: p.followerCount,\n  experience: p.experience || [],\n  education: p.education || [],\n  skills: p.skills || [],\n  raw_data: p\n}));\n\nreturn {\n  json: {\n    search_id: searchInfo.search_id,\n    profiles_count: transformedProfiles.length,\n    profiles: transformedProfiles\n  }\n};"
      },
      "id": "snr-transform-results",
      "name": "Transform Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 304]
