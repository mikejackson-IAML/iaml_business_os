      "typeVersion": 1.2,
      "position": [-1800, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/rpc/log_workflow_start",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_workflow_id\": \"sales-nav-results-handler\",\n  \"p_workflow_name\": \"Sales Navigator Results Handler\",\n  \"p_execution_id\": \"{{ $execution.id }}\",\n  \"p_trigger_type\": \"schedule\",\n  \"p_trigger_data\": {}\n}",
        "options": {}
      },
      "id": "snr-log-start",
      "name": "Log Workflow Start",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1600, 600],
      "credentials": {
        "httpHeaderAuth": {
          "id": "supabase-rest-api",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/sales_nav_searches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "id,search_name,search_url,apify_run_id,apify_dataset_id,started_at"
            },
            {
              "name": "status",
              "value": "eq.processing"
            },
            {
              "name": "apify_run_id",
              "value": "not.is.null"
            },
            {
              "name": "order",
              "value": "started_at.asc"
            },
            {
              "name": "limit",
              "value": "5"
            }
          ]
        },
        "options": {}
      },
      "id": "snr-get-processing",
      "name": "Get Processing Searches",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1400, 600],
      "alwaysOutputData": true,
      "credentials": {
        "httpHeaderAuth": {
          "id": "supabase-rest-api",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Store run_id and parse webhook payload\nconst body = $input.first().json.body || $input.first().json;\nconst runId = body.actorRunId || body.runId || body.id;\nconst status = body.status || 'SUCCEEDED';\n\nif (!runId) {\n  throw new Error('No run ID in webhook payload');\n}\n\nreturn {\n  json: {\n    apify_run_id: runId,\n    apify_status: status,\n    source: 'webhook'\n  }\n};"
      },
      "id": "snr-parse-webhook",
      "name": "Parse Webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1600, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/sales_nav_searches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "id,search_name,search_url,apify_run_id,apify_dataset_id"
            },
            {
              "name": "apify_run_id",
              "value": "=eq.{{ $json.apify_run_id }}"
            },
            {
              "name": "status",
              "value": "eq.processing"
            },
            {
              "name": "limit",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "snr-find-search",
      "name": "Find Search by Run ID",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1400, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "supabase-rest-api",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check if search found\nconst result = $input.first().json;\nconst search = Array.isArray(result) ? result[0] : result;\nconst found = search && search.id;\n\nreturn [{ json: { found: !!found, search: search || null } }];"
      },
      "id": "snr-check-found",
      "name": "Check Found",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1200, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-search",
              "leftValue": "={{ $json.found }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "snr-has-search",
      "name": "Found Search?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-1000, 400]
    },
    {
      "parameters": {
        "jsCode": "// Store run_id and check processing searches\nconst logResult = $('Log Workflow Start').first().json;\nconst searches = $('Get Processing Searches').first().json;\n\nconst staticData = $getWorkflowStaticData('global');\nstaticData.run_id = logResult.run_id || logResult;\n\nconst hasSearches = Array.isArray(searches) ? searches.length > 0 : (searches && searches.id);\nconst searchList = Array.isArray(searches) ? searches : (searches && searches.id ? [searches] : []);\n\nreturn [{ json: { has_processing: hasSearches, searches: searchList } }];"
      },
      "id": "snr-check-processing",
      "name": "Check Processing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1200, 600]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-processing",
              "leftValue": "={{ $json.has_processing }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "snr-has-processing",
      "name": "Has Processing?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-1000, 600]
    },
    {
      "parameters": {
        "jsCode": "// Split searches for processing\nconst searches = $json.searches || [];\nreturn searches.map(s => ({ json: s }));"
      },
      "id": "snr-split-processing",
      "name": "Split Processing Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-800, 504]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.apify.com/v2/actor-runs/{{ $json.apify_run_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "options": {}
      },
      "id": "snr-check-run-status",
      "name": "Check Apify Run Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-600, 504],
      "credentials": {
        "httpQueryAuth": {
          "id": "apify-token",
          "name": "Apify API Token"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const runData = $input.first().json;\nconst searchData = $('Split Processing Items').first().json;\n\nconst status = runData.data?.status || runData.status;\nconst isCompleted = ['SUCCEEDED', 'FAILED', 'ABORTED', 'TIMED-OUT'].includes(status);\n\nreturn {\n  json: {\n    search_id: searchData.id,\n    search_name: searchData.search_name,\n    apify_run_id: searchData.apify_run_id,\n    apify_dataset_id: runData.data?.defaultDatasetId || searchData.apify_dataset_id,\n    apify_status: status,\n    is_completed: isCompleted,\n    is_success: status === 'SUCCEEDED'\n  }\n};"
      },
      "id": "snr-process-status",
      "name": "Process Run Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-400, 504]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
