    {
      "parameters": {
        "jsCode": "const params = $('Count Tagged Contacts').first().json;\n\nconst registrantName = `${params.first_name} ${params.last_name}`.trim() || params.registrant_email;\n\nconst message = `:handshake: *Colleague Expansion Triggered*\\n\\n` +\n  `*Registrant:* ${registrantName} (${params.registrant_email})\\n` +\n  `*Company:* ${params.company_name}\\n\\n` +\n  `*Existing contacts tagged for CE:* ${params.tagged_contacts_count}\\n` +\n  `*Sales Nav search queued:* ${params.sales_nav_search_name}\\n\\n` +\n  `Tagged contacts will be exported to SmartLead SL-CE on next exporter run (~2 hrs).`;\n\nreturn [{ json: { slack_message: message, ...params } }];"
      },
