      "parameters": {
        "jsCode": "// Check if we have a search to process\nconst result = $input.first().json;\nconst hasSearch = Array.isArray(result) ? result.length > 0 : (result && result.id);\nconst search = Array.isArray(result) ? result[0] : result;\n\n// Store daily limit info for later\nconst dailyLimit = $('Check Daily Limit').first().json;\n\nreturn [{\n  json: {\n    has_search: !!(hasSearch && search && search.id),\n    search: search || null,\n    daily_remaining: dailyLimit.remaining,\n    profiles_scraped_today: dailyLimit.profiles_scraped\n  }\n}];"
      },
