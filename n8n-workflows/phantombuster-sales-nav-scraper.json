      "id": "pb-poll-status",
      "name": "Poll Agent Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "dvpqARPbngYw9Pgn",
          "name": "PhantomBuster API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check agent status\nconst response = $input.first().json;\nconst prevData = $('Process Launch Response').first().json;\n\n// FIXED: PhantomBuster uses lastEndType, not lastEndStatus\nconst status = response.lastEndType || response.status || 'unknown';\nconst isRunning = status === 'running' || status === 'launched';\nconst isFinished = status === 'finished' || status === 'success';\nconst isFailed = status === 'error' || status === 'failed';\n\n// Get static data for poll count\nconst staticData = $getWorkflowStaticData('global');\nstaticData.poll_count = (staticData.poll_count || 0) + 1;\n\n// Max 60 polls (30 minutes) - Option A scrapes up to 1500 profiles\nconst maxPolls = 60;\nconst shouldContinuePolling = isRunning && staticData.poll_count < maxPolls;\n\nreturn [{\n  json: {\n    search_id: prevData.search_id,\n    container_id: prevData.container_id,\n    pb_agent_id: prevData.pb_agent_id,\n    batch_size: prevData.batch_size,\n    status: status,\n    is_running: isRunning,\n    is_finished: isFinished,\n    is_failed: isFailed,\n    should_poll: shouldContinuePolling,\n    poll_count: staticData.poll_count,\n    output_url: response.s3Folder || null\n  }\n}];"
      },
      "id": "pb-check-status",
      "name": "Check Agent Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 400]
    },
    {
