        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_search_id\": \"{{ $json.search.id }}\",\n  \"p_pb_agent_id\": {{ $json.search.pb_agent_id ? '\"' + $json.search.pb_agent_id + '\"' : 'null' }}\n}",
