      "parameters": {
        "jsCode": "// Parse webhook input for queue URL request\nconst body = $input.first().json.body || $input.first().json;\nlet searchName = body.search_name || body.searchName || 'Unnamed Search';\nlet searchUrl = body.url || body.search_url || body.searchUrl || '';\nlet pbAgentId = body.pb_agent_id || body.phantombuster_agent_id || null;\n\n// Validate URL\nif (!searchUrl.includes('linkedin.com/sales')) {\n  throw new Error('Invalid Sales Navigator URL. Must contain linkedin.com/sales');\n}\n\nreturn [{\n  json: {\n    search_name: searchName,\n    search_url: searchUrl,\n    pb_agent_id: pbAgentId\n  }\n}];"
      },
