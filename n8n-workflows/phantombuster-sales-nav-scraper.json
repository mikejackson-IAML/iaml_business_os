      "id": "pb-fetch-output",
      "name": "Fetch Results",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1800, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "dvpqARPbngYw9Pgn",
          "name": "PhantomBuster API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Transform PhantomBuster output to our format\nconst output = $input.first().json;\nconst prevData = $('Check Agent Status').first().json;\n\n// PhantomBuster returns results in various formats\nlet profiles = [];\n\n// Try to extract profiles from different response structures\nif (output.output && Array.isArray(output.output)) {\n  profiles = output.output;\n} else if (output.resultObject && Array.isArray(output.resultObject)) {\n  profiles = output.resultObject;\n} else if (Array.isArray(output)) {\n  profiles = output;\n} else if (output.data && Array.isArray(output.data)) {\n  profiles = output.data;\n}\n\n// Filter out any non-profile objects\nprofiles = profiles.filter(p => p && (p.profileUrl || p.linkedInProfileUrl || p.profile_url));\n\nreturn [{\n  json: {\n    search_id: prevData.search_id,\n    pb_agent_id: prevData.pb_agent_id,\n    container_id: prevData.container_id,\n    profiles: profiles,\n    profile_count: profiles.length,\n    batch_size: prevData.batch_size\n  }\n}];"
      },
      "id": "pb-transform-output",
      "name": "Transform Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://mnkuffgxemfyitcjnjdc.supabase.co/rest/v1/rpc/insert_pb_profiles",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_search_id\": \"{{ $json.search_id }}\",\n  \"p_profiles\": {{ JSON.stringify($json.profiles) }}\n}",
        "options": {}
      },
      "id": "pb-insert-profiles",
      "name": "Insert Profiles",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2200, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "Dy6aCSbL5Tup4TnE",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get insert result and prepare progress update\nconst insertResult = $input.first().json;\nconst transformData = $('Transform Results').first().json;\n\nconst profilesAdded = insertResult.inserted || 0;\n\nreturn [{\n  json: {\n    search_id: transformData.search_id,\n    pb_agent_id: transformData.pb_agent_id,\n    profiles_added: profilesAdded,\n    profiles_skipped: insertResult.skipped || 0,\n    total_in_batch: transformData.profile_count,\n    sales_nav_search_id: insertResult.sales_nav_search_id\n  }\n}];"
      },
      "id": "pb-process-insert",
