    {
      "parameters": {
        "method": "POST",
        "url": "https://mnkuffgxemfyitcjnjdc.supabase.co/rest/v1/rpc/process_sales_nav_to_contacts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_search_id\": \"{{ $('Process Insert Result').first().json.sales_nav_search_id }}\"\n}",
        "options": {}
      },
      "id": "pb-process-contacts",
      "name": "Process to Contacts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2800, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "Dy6aCSbL5Tup4TnE",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check daily limit after processing to see if we should continue or pause\nconst processResult = $('Process Insert Result').first().json;\nconst dailyLimit = $('Check Daily Limit').first().json;\nconst newDayTotal = dailyLimit.profiles_scraped + processResult.profiles_added;\nconst limitReached = newDayTotal >= dailyLimit.daily_limit;\n\nreturn [{\n  json: {\n    search_id: processResult.search_id,\n    profiles_added: processResult.profiles_added,\n    day_total: newDayTotal,\n    daily_limit: dailyLimit.daily_limit,\n    limit_reached: limitReached,\n    should_continue: !limitReached\n  }\n}];"
