      "position": [-200, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "Dy6aCSbL5Tup4TnE",
          "name": "Supabase REST API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Prepare PhantomBuster launch parameters\nconst searchData = $('Check Search Available').first().json;\nconst search = searchData.search;\nconst dailyRemaining = searchData.daily_remaining;\n\n// Option A: 1500 profiles per run (matches PhantomBuster config)\n// Use min of 1500 or remaining daily limit\nconst batchSize = Math.min(1500, dailyRemaining);\n\n// Get offset for resume (0 for new searches, current_offset for paused)\nconst offset = search.current_offset || 0;\n\n// Default Phantom ID: IAML Sales Nav Scraper\nconst defaultPhantomId = '261754944017446';\n\nreturn [{\n  json: {\n    search_id: search.id,\n    search_name: search.search_name,\n    search_url: search.search_url,\n    pb_agent_id: search.pb_agent_id || defaultPhantomId,\n    offset: offset,\n    batch_size: batchSize,\n    is_resume: search.status === 'paused'\n  }\n}];"
      },
      "id": "pb-prepare-launch",
      "name": "Prepare Launch Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.phantombuster.com/api/v2/agents/launch",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"id\": \"{{ $json.pb_agent_id }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "pb-launch-agent",
      "name": "Launch PhantomBuster",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [200, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "dvpqARPbngYw9Pgn",
          "name": "PhantomBuster API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Process launch response\nconst response = $input.first().json;\nconst launchParams = $('Prepare Launch Params').first().json;\n\nif (response.containerId) {\n  return [{\n    json: {\n      success: true,\n      search_id: launchParams.search_id,\n      container_id: response.containerId,\n      pb_agent_id: launchParams.pb_agent_id || response.agentId,\n      batch_size: launchParams.batch_size\n    }\n  }];\n} else {\n  return [{\n    json: {\n      success: false,\n      search_id: launchParams.search_id,\n      error: response.error || response.message || 'Unknown PhantomBuster error'\n    }\n  }];\n}"
      },
      "id": "pb-process-launch",
      "name": "Process Launch Response",
      "type": "n8n-nodes-base.code",
