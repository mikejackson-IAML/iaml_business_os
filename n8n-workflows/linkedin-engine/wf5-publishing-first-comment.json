      "parameters": {
        "jsCode": "// Prepare data for LinkedIn publish node\n// Pass forward all needed data from previous nodes\n\nconst post = $('Fetch Post Details').first().json;\nconst calendarData = $('Check Calendar Slot').first().json;\nconst dateData = $('Build Today\\'s Date').first().json;\n\nreturn [{\n  json: {\n    post_id: calendarData.post_id,\n    calendar_id: calendarData.calendar_id,\n    full_text: post.full_text || '',\n    first_comment_text: post.first_comment_text || '',\n    hook_text: post.hook_text || '',\n    hook_category: post.hook_category || '',\n    hook_variation: post.hook_variation || '',\n    series: post.series || calendarData.series || '',\n    pillar: post.pillar || calendarData.pillar || '',\n    person_urn: dateData.person_urn,\n    retry_count: dateData.retry_count\n  }\n}];"
      },
