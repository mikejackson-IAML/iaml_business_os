      "parameters": {
        "jsCode": "// Build today's date using workflow timezone (America/Chicago)\n// Generate run_id for workflow_runs tracking\n\nfunction uuidv4() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\nconst today = $now.toISODate();\n\nreturn [{\n  json: {\n    today: today,\n    run_id: uuidv4(),\n    started_at: new Date().toISOString(),\n    person_urn: 'urn:li:person:PLACEHOLDER_PERSON_URN',\n    retry_count: 0\n  }\n}];"
      },
