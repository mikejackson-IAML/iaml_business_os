      "parameters": {
        "jsCode": "// Check retry count for LinkedIn publish failure\n// If retry_count < 1, allow one retry\n\nconst prevData = $('Prepare Publish Data').first().json;\nconst currentRetryCount = prevData.retry_count || 0;\nconst MAX_RETRIES = 1;\n\nif (currentRetryCount < MAX_RETRIES) {\n  return [{\n    json: {\n      should_retry: true,\n      retry_count: currentRetryCount + 1,\n      post_id: prevData.post_id,\n      calendar_id: prevData.calendar_id,\n      full_text: prevData.full_text,\n      first_comment_text: prevData.first_comment_text,\n      hook_text: prevData.hook_text,\n      hook_category: prevData.hook_category,\n      hook_variation: prevData.hook_variation,\n      series: prevData.series,\n      pillar: prevData.pillar,\n      person_urn: prevData.person_urn\n    }\n  }];\n} else {\n  return [{\n    json: {\n      should_retry: false,\n      post_id: prevData.post_id,\n      calendar_id: prevData.calendar_id\n    }\n  }];\n}"
      },
