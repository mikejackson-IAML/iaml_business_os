      "parameters": {
        "jsCode": "// Check if we have a calendar slot with a linked post_id\n// The Supabase response is an array of matching rows\n\nconst response = $input.first().json;\nlet slots = [];\n\nif (Array.isArray(response)) {\n  slots = response;\n} else if (response && response.id) {\n  slots = [response];\n}\n\n// Find first slot with a post_id\nconst slotWithPost = slots.find(s => s.post_id !== null && s.post_id !== undefined);\n\nif (!slotWithPost) {\n  return [{\n    json: {\n      has_slot: false,\n      skip_reason: slots.length === 0 ? 'No calendar slot for today' : 'Calendar slot has no linked post_id'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    has_slot: true,\n    calendar_id: slotWithPost.id,\n    post_id: slotWithPost.post_id,\n    series: slotWithPost.series || null,\n    pillar: slotWithPost.pillar || null\n  }\n}];"
      },
