    {
      "parameters": {
        "jsCode": "// Extract the post URN from the LinkedIn node response\n// The LinkedIn n8n node may return the URN in different fields\n// Check multiple locations for compatibility\n\nconst response = $input.first().json;\nconst prevData = $('Prepare Publish Data').first().json;\n\n// Check possible URN locations\nlet postUrn = response.id || response.urn || response['x-restli-id'];\n\n// If using HTTP Request node, check headers\nif (!postUrn && response.$response?.headers?.['x-restli-id']) {\n  postUrn = response.$response.headers['x-restli-id'];\n}\n\n// Try activity field\nif (!postUrn && response.activity) {\n  postUrn = 'urn:li:activity:' + response.activity;\n}\n\nif (!postUrn) {\n  throw new Error('Failed to extract LinkedIn post URN from response. Response keys: ' + Object.keys(response).join(', '));\n}\n\n// Construct the LinkedIn post URL\nconst linkedinUrl = `https://www.linkedin.com/feed/update/${postUrn}`;\n\nreturn [{\n  json: {\n    linkedin_post_urn: postUrn,\n    linkedin_url: linkedinUrl,\n    published_at: new Date().toISOString(),\n    post_id: prevData.post_id,\n    calendar_id: prevData.calendar_id,\n    first_comment_text: prevData.first_comment_text,\n    hook_text: prevData.hook_text,\n    hook_category: prevData.hook_category,\n    hook_variation: prevData.hook_variation,\n    series: prevData.series,\n    pillar: prevData.pillar,\n    full_text: prevData.full_text,\n    person_urn: prevData.person_urn\n  }\n}];"
      },
