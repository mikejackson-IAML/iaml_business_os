        "jsCode": "// Log skip - no calendar slot or post not approved\n// Determine the skip reason from upstream data\n\nlet skipReason = 'Unknown';\n\ntry {\n  const calendarCheck = $('Check Calendar Slot').first().json;\n  if (!calendarCheck.has_slot) {\n    skipReason = calendarCheck.skip_reason || 'No calendar slot with linked post for today';\n  } else {\n    const post = $('Fetch Post Details').first().json;\n    skipReason = `Post status is '${post.status}' (not approved)`;\n  }\n} catch (e) {\n  skipReason = 'No calendar slot for today';\n}\n\nreturn [{\n  json: {\n    skip_reason: skipReason\n  }\n}];"
      },
